<button id="theme-toggle" class="btn btn--ghost" aria-label="Alternar tema claro/escuro">
  <span class="only-light" aria-hidden="true">Noite</span>
  <span class="only-dark" aria-hidden="true">Dia</span>
</button>
<style is:global>
  .dark .only-light { display: none; }
  html:not(.dark) .only-dark { display: none; }
</style>
<script>
  const KEY = 'mintly-theme'
  const root = document.documentElement
  const saved = localStorage.getItem(KEY)
  if (saved === 'dark') root.classList.add('dark')
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    root.classList.toggle('dark')
    localStorage.setItem(KEY, root.classList.contains('dark') ? 'dark' : 'light')
  })
</script>

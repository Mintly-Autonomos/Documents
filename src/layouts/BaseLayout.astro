---
import '../styles/global.css'
import ThemeToggle from '../components/ThemeToggle.astro'
import CommandPalette from '../components/CommandPalette.astro'
interface Props { title: string, description?: string, ogType?: string, showMenuButton?: boolean }
const {
  title,
  description = 'Documentação do projeto Mintly — releases, specs e diagramas da equipe.',
  ogType = 'article',
  showMenuButton = false,
} = Astro.props
const base = import.meta.env.BASE_URL
const site = Astro.site?.toString().replace(/\/$/, '') ?? ''
const pageUrl = `${site}${base}${Astro.url.pathname.replace(base, '')}`
const ogImage = `${site}${base}/og.png`
---
<!doctype html>
<html lang="pt-br">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Mintly · Documentos" />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <a class="skip-link" href="#conteudo">Pular para o conteúdo</a>
    <header class="site-header">
      <div class="site-header__bar">
        <span style="display:flex;align-items:baseline;gap:14px;">
          {showMenuButton && (
            <button id="menu-btn" class="btn btn--ghost menu-btn" aria-expanded="false" aria-controls="sidebar">
              Índice
            </button>
          )}
          <a class="wordmark" href={base}>Mintly <em>· Documentos</em></a>
        </span>
        <nav class="site-header__actions" aria-label="Ações do site">
          <a class="btn btn--ghost" href={`${base}/buscar`}>Buscar <span class="meta" aria-hidden="true">⌘K</span></a>
          <ThemeToggle />
        </nav>
      </div>
      <hr class="rule--double" />
    </header>
    <slot />
    <CommandPalette />
  </body>
</html>

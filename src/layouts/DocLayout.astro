---
import BaseLayout from './BaseLayout.astro'
import Sidebar from '../components/Sidebar.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import type { FolderNode } from '../lib/content-tree'
interface Props { title: string, description?: string, tree: FolderNode, current: string }
const { title, description, tree, current } = Astro.props
---
<BaseLayout title={title} description={description} showMenuButton={true}>
  <div class="doc-shell">
    <Sidebar tree={tree} current={current} />
    <main id="conteudo" class="doc-main">
      <Breadcrumb path={current} />
      <slot />
    </main>
  </div>
</BaseLayout>
